# environment variables for cuvis.ai examples

# Hugging Face private dataset access token
HF_TOKEN=hf_xxx_your_read_token

# Optional: override dataset repo and local directory
HF_REPO_ID=nghorbani/Hyperspektral-Small
HF_LOCAL_DIR=data/Hyperspektral-Small

# Optional: default work directory for runs/reports
WORK_DIR=./work_dirs/exp
